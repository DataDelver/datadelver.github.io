# Git LFS file patterns for images and large binaries
# Track common image file extensions repository-wide
**/*.png filter=lfs diff=lfs merge=lfs -text
**/*.jpg filter=lfs diff=lfs merge=lfs -text
**/*.jpeg filter=lfs diff=lfs merge=lfs -text
**/*.gif filter=lfs diff=lfs merge=lfs -text
**/*.webp filter=lfs diff=lfs merge=lfs -text
**/*.svg filter=lfs diff=lfs merge=lfs -text

# Also explicitly track images under known asset directories
/assets/images/** filter=lfs diff=lfs merge=lfs -text
/docs/assets/images/** filter=lfs diff=lfs merge=lfs -text
/site/assets/images/** filter=lfs diff=lfs merge=lfs -text
# Optionally track other large binary files (uncomment if wanted)
# **/*.mp4 filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.webp filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text
